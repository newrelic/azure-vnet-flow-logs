{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "newRelicLicenseKey": {
            "type": "securestring",
            "metadata": {
                "description": "Required. New Relic License Key"
            }
        },
        "sourceStorageAccountName": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "Optional. Name of the existing storage account where VNet Flow Logs PT1H.json files are stored. Must be in the same resource group as this deployment. Leave this blank to create a new storage account (its name will start with 'nrvnetflsrc')."
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "Optional. Region where all resources included in this template will be deployed. Leave this blank to use the same region as the one of the resource group."
            }
        },
        "newRelicEndpoint": {
            "type": "string",
            "defaultValue": "https://log-api.newrelic.com/log/v1",
            "allowedValues": [
                "https://log-api.newrelic.com/log/v1",
                "https://log-api.eu.newrelic.com/log/v1",
                "https://log-api.jp.newrelic.com/log/v1"
            ],
            "metadata": {
                "description": "Optional. The Logs API endpoint for your New Relic account region. Select US (default), EU, or JP endpoint."
            }
        },
        "newRelicTags": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "Optional. Custom tags to add to logs sent to New Relic (semicolon-separated key:value pairs, e.g. env:prod;team:network)."
            }
        },
        "maxRetries": {
            "type": "int",
            "defaultValue": 3,
            "metadata": {
                "description": "Optional. Maximum number of retries when sending logs to New Relic."
            }
        },
        "retryInterval": {
            "type": "int",
            "defaultValue": 2000,
            "metadata": {
                "description": "Optional. Retry interval in milliseconds when sending logs to New Relic."
            }
        },
        "eventHubBatchSize": {
            "type": "int",
            "defaultValue": 10,
            "metadata": {
                "description": "Optional. Maximum number of events to process in a single batch from Event Hub."
            }
        },
        "eventHubPartitionCount": {
            "type": "int",
            "defaultValue": 32,
            "minValue": 1,
            "maxValue": 32,
            "metadata": {
                "description": "Optional. Number of Event Hub partitions to provision. Sets the maximum parallelism for the consumer function (one Flex Consumption instance can read from each partition concurrently). Default 32 is the Standard tier ceiling and adds no cost. Lower values reduce parallelism only; partition count is fixed at hub creation and cannot be changed later."
            }
        },
        "debugEnabled": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Optional. Enable debug logging for troubleshooting."
            }
        },
        "maximumInstanceCount": {
            "type": "int",
            "defaultValue": 100,
            "minValue": 1,
            "maxValue": 1000,
            "metadata": {
                "description": "Optional. Maximum number of instances for Flex Consumption plan."
            }
        },
        "instanceMemoryMB": {
            "type": "int",
            "defaultValue": 2048,
            "allowedValues": [
                512,
                2048,
                4096
            ],
            "metadata": {
                "description": "Optional. Memory allocation per instance in MB. Recommended: 2048MB."
            }
        }
    },
    "variables": {
        "uniqueResourceNameSuffix": "[uniqueString(resourceGroup().id)]",
        "location": "[if(empty(parameters('location')), resourceGroup().location, parameters('location'))]",

        "createNewSourceStorage": "[empty(parameters('sourceStorageAccountName'))]",
        "sourceStorageAccountNameResolved": "[if(variables('createNewSourceStorage'), concat('nrvnetflsrc', variables('uniqueResourceNameSuffix')), parameters('sourceStorageAccountName'))]",

        "eventHubNamespaceName": "[concat('nrvnetflowlogs-eventhub-namespace-', variables('uniqueResourceNameSuffix'))]",
        "eventHubName": "nrvnetflowlogs-eventhub",
        "eventHubConsumerGroupName": "nrvnetflowlogs-consumergroup",
        "eventHubAuthRuleName": "nrvnetflowlogs-consumer-policy",

        "eventGridSystemTopicName": "[concat('nrvnetflowlogs-eventgrid-topic-', variables('uniqueResourceNameSuffix'))]",
        "eventGridSubscriptionName": "[concat('nrvnetflowlogs-eventgrid-subscription-', variables('uniqueResourceNameSuffix'))]",

        "cursorStorageAccountName": "[concat('nrvnetflcur', variables('uniqueResourceNameSuffix'))]",
        "cursorTableName": "nrvnetflowlogscursors",

        "functionStorageAccountName": "[concat('nrvnetflfn', variables('uniqueResourceNameSuffix'))]",
        "servicePlanName": "[concat('nrvnetflowlogs-serviceplan-', variables('uniqueResourceNameSuffix'))]",
        "functionAppName": "[concat('nrvnetflowlogs-forwarder-', variables('uniqueResourceNameSuffix'))]",

        "deploymentIdentityName": "[concat('nrvnetflowlogs-deploy-id-', variables('uniqueResourceNameSuffix'))]",
        "deploymentScriptName": "[concat('nrvnetflowlogs-deploy-script-', variables('uniqueResourceNameSuffix'))]",
        "websiteContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'de139f84-1756-47ae-9be6-808fbbe84772')]",
        "vnetFlowLogsForwarderFunctionArtifact": "https://github.com/newrelic/azure-vnet-flow-logs/releases/latest/download/VNetFlowForwarder.zip",

        "sourceStorageAccountId": "[resourceId('Microsoft.Storage/storageAccounts', variables('sourceStorageAccountNameResolved'))]",

        "flexConsumptionASP": {
            "kind": "functionapp,linux",
            "properties": {
                "reserved": true
            },
            "sku": {
                "tier": "FlexConsumption",
                "name": "FC1"
            }
        }
    },
    "resources": [
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-05-01",
            "name": "[variables('sourceStorageAccountNameResolved')]",
            "condition": "[variables('createNewSourceStorage')]",
            "location": "[variables('location')]",
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": false,
                "allowSharedKeyAccess": true,
                "networkAcls": {
                    "bypass": "AzureServices",
                    "defaultAction": "Allow"
                },
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "services": {
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                },
                "accessTier": "Hot"
            }
        },
        {
            "type": "Microsoft.EventHub/namespaces",
            "apiVersion": "2021-11-01",
            "name": "[variables('eventHubNamespaceName')]",
            "location": "[variables('location')]",
            "sku": {
                "name": "Standard",
                "tier": "Standard",
                "capacity": 1
            },
            "properties": {
                "zoneRedundant": false
            }
        },
        {
            "type": "Microsoft.EventHub/namespaces/eventhubs",
            "apiVersion": "2021-11-01",
            "name": "[concat(variables('eventHubNamespaceName'), '/', variables('eventHubName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
            ],
            "properties": {
                "messageRetentionInDays": 1,
                "partitionCount": "[parameters('eventHubPartitionCount')]"
            }
        },
        {
            "type": "Microsoft.EventHub/namespaces/eventhubs/consumergroups",
            "name": "[concat(variables('eventHubNamespaceName'), '/', variables('eventHubName'), '/', variables('eventHubConsumerGroupName'))]",
            "apiVersion": "2021-11-01",
            "dependsOn": [
                "[resourceId('Microsoft.EventHub/namespaces/eventhubs', variables('eventHubNamespaceName'), variables('eventHubName'))]"
            ],
            "properties": {}
        },
        {
            "type": "Microsoft.EventHub/namespaces/AuthorizationRules",
            "apiVersion": "2021-11-01",
            "name": "[concat(variables('eventHubNamespaceName'), '/', variables('eventHubAuthRuleName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.EventHub/namespaces', variables('eventHubNamespaceName'))]"
            ],
            "properties": {
                "rights": [
                    "Listen",
                    "Send"
                ]
            }
        },
        {
            "type": "Microsoft.EventGrid/systemTopics",
            "apiVersion": "2021-12-01",
            "name": "[variables('eventGridSystemTopicName')]",
            "location": "[variables('location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('sourceStorageAccountNameResolved'))]"
            ],
            "properties": {
                "source": "[variables('sourceStorageAccountId')]",
                "topicType": "Microsoft.Storage.StorageAccounts"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-05-01",
            "name": "[variables('cursorStorageAccountName')]",
            "location": "[variables('location')]",
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": false,
                "allowSharedKeyAccess": true,
                "publicNetworkAccess": "Enabled",
                "networkAcls": {
                    "bypass": "AzureServices",
                    "defaultAction": "Allow"
                },
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "services": {
                        "table": {
                            "keyType": "Account",
                            "enabled": true
                        },
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                },
                "accessTier": "Hot"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/tableServices",
            "apiVersion": "2022-09-01",
            "name": "[concat(variables('cursorStorageAccountName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('cursorStorageAccountName'))]"
            ],
            "properties": {}
        },
        {
            "type": "Microsoft.Storage/storageAccounts/tableServices/tables",
            "apiVersion": "2022-09-01",
            "name": "[concat(variables('cursorStorageAccountName'), '/default/', variables('cursorTableName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/tableServices', variables('cursorStorageAccountName'), 'default')]"
            ],
            "properties": {}
        },
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-05-01",
            "name": "[variables('functionStorageAccountName')]",
            "location": "[variables('location')]",
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": false,
                "allowSharedKeyAccess": true,
                "publicNetworkAccess": "Enabled",
                "networkAcls": {
                    "bypass": "AzureServices",
                    "defaultAction": "Allow"
                },
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "services": {
                        "file": {
                            "keyType": "Account",
                            "enabled": true
                        },
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                },
                "accessTier": "Hot"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices",
            "apiVersion": "2023-05-01",
            "name": "[concat(variables('functionStorageAccountName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('functionStorageAccountName'))]"
            ],
            "properties": {}
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2023-05-01",
            "name": "[concat(variables('functionStorageAccountName'), '/default/deployments')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('functionStorageAccountName'), 'default')]"
            ],
            "properties": {
                "publicAccess": "None"
            }
        },
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2023-12-01",
            "name": "[variables('servicePlanName')]",
            "location": "[variables('location')]",
            "kind": "[variables('flexConsumptionASP').kind]",
            "properties": "[variables('flexConsumptionASP').properties]",
            "sku": "[variables('flexConsumptionASP').sku]"
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2023-12-01",
            "name": "[variables('functionAppName')]",
            "location": "[variables('location')]",
            "kind": "functionapp,linux",
            "identity": {
                "type": "SystemAssigned"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', variables('servicePlanName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('functionStorageAccountName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', variables('functionStorageAccountName'), 'default', 'deployments')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('cursorStorageAccountName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts/tableServices/tables', variables('cursorStorageAccountName'), 'default', variables('cursorTableName'))]",
                "[resourceId('Microsoft.EventHub/namespaces/authorizationRules', variables('eventHubNamespaceName'), variables('eventHubAuthRuleName'))]"
            ],
            "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('servicePlanName'))]",
                "httpsOnly": true,
                "functionAppConfig": {
                    "deployment": {
                        "storage": {
                            "type": "blobContainer",
                            "value": "[concat('https://', variables('functionStorageAccountName'), '.blob.', environment().suffixes.storage, '/deployments')]",
                            "authentication": {
                                "type": "SystemAssignedIdentity"
                            }
                        }
                    },
                    "scaleAndConcurrency": {
                        "maximumInstanceCount": "[parameters('maximumInstanceCount')]",
                        "instanceMemoryMB": "[parameters('instanceMemoryMB')]"
                    },
                    "runtime": {
                        "name": "node",
                        "version": "22"
                    }
                },
                "siteConfig": {
                    "appSettings": [
                        {
                            "name": "AzureWebJobsStorage__accountName",
                            "value": "[variables('functionStorageAccountName')]"
                        },
                        {
                            "name": "EVENTHUB_NAME",
                            "value": "[variables('eventHubName')]"
                        },
                        {
                            "name": "EVENTHUB_CONSUMER_CONNECTION",
                            "value": "[listKeys(resourceId('Microsoft.EventHub/namespaces/authorizationRules', variables('eventHubNamespaceName'), variables('eventHubAuthRuleName')), '2021-11-01').primaryConnectionString]"
                        },
                        {
                            "name": "EVENTHUB_CONSUMER_GROUP",
                            "value": "[variables('eventHubConsumerGroupName')]"
                        },
                        {
                            "name": "SOURCE_STORAGE_CONNECTION",
                            "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('sourceStorageAccountNameResolved'), ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('sourceStorageAccountNameResolved')), '2023-05-01').keys[0].value, ';EndpointSuffix=', environment().suffixes.storage)]"
                        },
                        {
                            "name": "CURSOR_STORAGE_CONNECTION",
                            "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('cursorStorageAccountName'), ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('cursorStorageAccountName')), '2023-05-01').keys[0].value, ';EndpointSuffix=', environment().suffixes.storage)]"
                        },
                        {
                            "name": "CURSOR_RETENTION_HOURS",
                            "value": "48"
                        },
                        {
                            "name": "CURSOR_CLEANUP_SCHEDULE",
                            "value": "0 0 3 * * *"
                        },
                        {
                            "name": "MAX_CONSECUTIVE_FAILURES",
                            "value": "3"
                        },
                        {
                            "name": "NR_LICENSE_KEY",
                            "value": "[parameters('newRelicLicenseKey')]"
                        },
                        {
                            "name": "NR_ENDPOINT",
                            "value": "[parameters('newRelicEndpoint')]"
                        },
                        {
                            "name": "NR_TAGS",
                            "value": "[parameters('newRelicTags')]"
                        },
                        {
                            "name": "NR_MAX_RETRIES",
                            "value": "[string(parameters('maxRetries'))]"
                        },
                        {
                            "name": "NR_RETRY_INTERVAL",
                            "value": "[string(parameters('retryInterval'))]"
                        },
                        {
                            "name": "AzureFunctionsJobHost__extensions__eventHubs__maxEventBatchSize",
                            "value": "[string(parameters('eventHubBatchSize'))]"
                        },
                        {
                            "name": "DEBUG_ENABLED",
                            "value": "[string(parameters('debugEnabled'))]"
                        },
                        {
                            "name": "FUNCTIONS_EXTENSION_VERSION",
                            "value": "~4"
                        }
                    ],
                    "ftpsState": "Disabled"
                }
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceId('Microsoft.Web/sites', variables('functionAppName')), resourceId('Microsoft.Storage/storageAccounts', variables('functionStorageAccountName')), 'StorageBlobDataOwner')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('functionStorageAccountName'))]"
            ],
            "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('functionStorageAccountName'))]",
            "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b7e6dc6d-f1e8-4753-8033-0f276bb0955b')]",
                "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2023-12-01', 'Full').identity.principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceId('Microsoft.Web/sites', variables('functionAppName')), resourceId('Microsoft.Storage/storageAccounts', variables('cursorStorageAccountName')), 'StorageTableDataContributor')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('cursorStorageAccountName'))]"
            ],
            "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('cursorStorageAccountName'))]",
            "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3')]",
                "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2023-12-01', 'Full').identity.principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
            "apiVersion": "2023-01-31",
            "name": "[variables('deploymentIdentityName')]",
            "location": "[variables('location')]"
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceId('Microsoft.Web/sites', variables('functionAppName')), variables('deploymentIdentityName'), 'WebsiteContributor')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deploymentIdentityName'))]"
            ],
            "scope": "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
            "properties": {
                "roleDefinitionId": "[variables('websiteContributorRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deploymentIdentityName')), '2023-01-31', 'Full').properties.principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.Resources/deploymentScripts",
            "apiVersion": "2023-08-01",
            "name": "[variables('deploymentScriptName')]",
            "location": "[variables('location')]",
            "kind": "AzureCLI",
            "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                    "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deploymentIdentityName'))]": {}
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deploymentIdentityName'))]",
                "[extensionResourceId(resourceId('Microsoft.Web/sites', variables('functionAppName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.Web/sites', variables('functionAppName')), variables('deploymentIdentityName'), 'WebsiteContributor'))]"
            ],
            "properties": {
                "azCliVersion": "2.61.0",
                "timeout": "PT30M",
                "retentionInterval": "PT1H",
                "cleanupPreference": "OnSuccess",
                "environmentVariables": [
                    {
                        "name": "ZIP_URL",
                        "value": "[variables('vnetFlowLogsForwarderFunctionArtifact')]"
                    },
                    {
                        "name": "FUNCTION_APP",
                        "value": "[variables('functionAppName')]"
                    },
                    {
                        "name": "RESOURCE_GROUP",
                        "value": "[resourceGroup().name]"
                    },
                    {
                        "name": "TARGET_FUNCTION",
                        "value": "VNetFlowLogsRelay"
                    }
                ],
                "scriptContent": "set -euo pipefail\n\necho 'Downloading package via python urllib (curl not preinstalled, python is)...'\npython3 -c \"import os, urllib.request; urllib.request.urlretrieve(os.environ['ZIP_URL'], '/tmp/package.zip')\"\nls -la /tmp/package.zip\n\necho 'Deploying via az functionapp deployment source config-zip (Flex-supported path)...'\naz functionapp deployment source config-zip \\\n  --resource-group \"$RESOURCE_GROUP\" \\\n  --name \"$FUNCTION_APP\" \\\n  --src /tmp/package.zip \\\n  --build-remote false \\\n  --timeout 900\n\necho \"Waiting for $TARGET_FUNCTION to register on the function host...\"\nfor i in $(seq 1 60); do\n  if az functionapp function show \\\n       --resource-group \"$RESOURCE_GROUP\" \\\n       --name \"$FUNCTION_APP\" \\\n       --function-name \"$TARGET_FUNCTION\" >/dev/null 2>&1; then\n    echo \"$TARGET_FUNCTION registered.\"\n    exit 0\n  fi\n  echo 'Function not yet registered, sleeping 10s...'\n  sleep 10\ndone\n\necho \"Timed out waiting for $TARGET_FUNCTION to register after 10 minutes.\"\nexit 1\n"
            }
        },
        {
            "type": "Microsoft.EventGrid/systemTopics/eventSubscriptions",
            "apiVersion": "2021-12-01",
            "name": "[concat(variables('eventGridSystemTopicName'), '/', variables('eventGridSubscriptionName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.EventGrid/systemTopics', variables('eventGridSystemTopicName'))]",
                "[resourceId('Microsoft.Resources/deploymentScripts', variables('deploymentScriptName'))]"
            ],
            "properties": {
                "destination": {
                    "endpointType": "AzureFunction",
                    "properties": {
                        "resourceId": "[resourceId('Microsoft.Web/sites/functions', variables('functionAppName'), 'VNetFlowLogsRelay')]",
                        "maxEventsPerBatch": 1,
                        "preferredBatchSizeInKilobytes": 64
                    }
                },
                "filter": {
                    "includedEventTypes": [
                        "Microsoft.Storage.BlobCreated"
                    ],
                    "enableAdvancedFilteringOnArrays": true,
                    "advancedFilters": [
                        {
                            "operatorType": "StringContains",
                            "key": "subject",
                            "values": [
                                "insights-logs-flowlogflowevent"
                            ]
                        }
                    ],
                    "subjectEndsWith": "PT1H.json"
                },
                "labels": [],
                "eventDeliverySchema": "EventGridSchema",
                "retryPolicy": {
                    "maxDeliveryAttempts": 30,
                    "eventTimeToLiveInMinutes": 1440
                }
            }
        }
    ]
}
